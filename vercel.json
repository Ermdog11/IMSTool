{
  "version": 2,
  "functions": {
    "api/scan.js": {
      "maxDuration": 300
    },
    "api/podcasts.js": {
      "maxDuration": 60
    },
    "api/digest.js": {
      "maxDuration": 60
    },
    "api/morning-brief.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "crons": [
    {
      "path": "/api/digest",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/morning-brief",
      "schedule": "0 8 * * *"
    }
  ]
}
