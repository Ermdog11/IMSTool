{
  "version": 2,
  "functions": {
    "api/scan.js": {
      "maxDuration": 60
    },
    "api/digest.js": {
      "maxDuration": 300
    },
    "api/morning-brief.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/digest",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/morning-brief",
      "schedule": "0 8 * * *"
    }
  ]
}
